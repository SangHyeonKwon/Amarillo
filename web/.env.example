# Base URL of the defi-tx-indexer REST API.
# The dashboard runs in the browser, so this must be reachable from the
# browser (not a docker-internal hostname). Default matches the api service
# published port in docker-compose.yml.
VITE_API_BASE_URL=http://localhost:3000

# Optional browser base path when serving under a subpath.
# - "/" for root hosting (default)
# - "/dash" to serve at https://host/dash
VITE_APP_BASE_PATH=/
