# PostgreSQL connection (required)
DATABASE_URL=postgres://user:password@localhost:5432/defi_analytics

# Admin/write API key (S16/M006/D023 — required, no silent default)
# Protects POST/DELETE on /v1/{contract-labels,alert-subscriptions}*.
# Recommended: 32+ bytes random (hex 64 chars). Rotation = env update + restart.
# GET endpoints remain public (embed-friendly). See docs/api-failed-tx.md#Authentication.
AMARILLO_ADMIN_API_KEY=change-me-to-a-long-random-key-at-least-32-bytes

# Ethereum RPC endpoint (required)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Optional: WebSocket endpoint for subscriptions
WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Indexer configuration
RUST_LOG=indexer=info,db=info,decoder=debug
MAX_CONCURRENT_BLOCKS=10
BATCH_SIZE=100

# TUI (crates/tui) — terminal client over the REST API.
# Only AMARILLO_API_URL is needed; the TUI never touches Postgres directly.
AMARILLO_API_URL=http://127.0.0.1:3000
# Optional overrides:
# AMARILLO_TUI_REFRESH_SECS=10   # auto-poll interval
# AMARILLO_TUI_TIMEOUT_SECS=15   # per-request HTTP timeout
# AMARILLO_TUI_LOG_DIR=.         # where amarillo-tui.log is written (TUI never logs to stdout)
